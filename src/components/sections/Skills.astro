---
import Section from "@/components/Section.astro";

import { skills } from "cv.json";
---

<Section title="Skills">
  <ul>
    {
      skills.map(({ name, level }) => (
        <li>
          <span>{name}</span>
        </li>
      ))
    }
  </ul>

  <style>
    ul {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    li {
      background-color: #eee;
      color: #333;
      padding: 0.2rem 0.6rem;
      border-radius: 6px;
      font-size: 0.8rem;
      font-weight: 500;
    }
  </style>
</Section>
