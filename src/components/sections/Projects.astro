---
import Section from "@/components/Section.astro";
import { projects } from "cv.json";
---

<Section title="Proyectos">
  <ul>
    {
      projects.map(({ url, isActive, description, name, highlights }) => {
        return (
          <li>
            <article>
              <header>
                <h3>
                  <a href={url} title={`View Project ${name}`} target="_blank">
                    {name}
                  </a>
                  {isActive && <span>&bull;</span>}
                </h3>
                <p>{description}</p>
              </header>
              <footer>
                {highlights.map((highlight) => {
                  return <span>{highlight}</span>;
                })}
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    list-style: none;
    gap: 1rem;
    margin-inline: -16px;
  }
  article {
    border: 1px solid #f2f2f2;
    gap: 10px;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    padding: 16px;
    height: 100%;
  }
  article header {
    flex: 1;
  }
  article h3 {
    margin-bottom: 4px;
  }
  article h3 span {
    color: rgb(18, 116, 116);
  }
  article a {
    text-decoration: none;
    color: #111;
  }
  article a:hover {
    text-decoration: underline;
  }
  article p {
    font-size: 0.75rem;
    line-height: 1.2rem;
    margin-bottom: 6px;
  }
  footer {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 0.6rem;
  }
  footer span {
    background: #eee;
    color: #666;
    font-size: 0.6rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
</style>
